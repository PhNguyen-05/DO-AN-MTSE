    {
      "name": "Get User Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "pm.test(\"Message matches expected response\", function () {\r",
              "    pm.expect(response).to.have.property(\"message\");\r",
              "    pm.expect(response.message).to.eql(\"Chào mừng Học viên\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5ZmVkOWMxM2M3NTVkOGM3OTAxN2VkZiIsInJvbGUiOiJ1c2VyIiwiaWF0IjoxNzc4NDcwMDE2LCJleHAiOjE3Nzg0NzA5MTZ9.vz8q82hmYlKpmGGCEPK_BKHfzWSzyCgHFZWYZq6cFHU",
