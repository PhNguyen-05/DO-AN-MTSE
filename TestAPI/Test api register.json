    {
      "name": "verify otp",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Trang Verify OTP load thành công\", () => {",
              "    pm.expect(pm.response.code).to.equal(200);",
              "});",
              "",
              "pm.test(\"Có chứa email trong response\", () => {",
              "    const emailParam = pm.request.url.query.get('email');",
              "    if (emailParam) {",
              "        pm.expect(pm.response.text()).to.include(emailParam);",
              "    }",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/verify-otp?email=testuser@gmail.com",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "verify-otp"
          ],
          "query": [
            {
              "key": "email",
              "value": "testuser@gmail.com"
            }
          ]
        },
        "description": "This is a GET request and it is used to \"get\" data from an endpoint. There is no request body for a GET request, but you can use query parameters to help specify the resource you want data on (e.g., in this request, we have `id=1`).\n\nA successful GET response will have a `200 OK` status, and should include some kind of response body - for example, HTML web content or JSON data."
      },
