<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Thông tin cá nhân</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="p-5 bg-light">
    <div class="container bg-white p-4 rounded shadow">
        <h2 id="welcome-msg">Thông tin cá nhân</h2>
        <hr>
        <button class="btn btn-danger" onclick="logout()">Đăng xuất</button>
    </div>

    <script>
        async function fetchProfile() {
            const token = localStorage.getItem('accessToken');
            const welcomeMsg = document.getElementById('welcome-msg');

            const url = window.location.pathname.includes('admin')
                ? '/admin/profile/data'
                : '/user/profile/data';

            try {
                const response = await fetch(url, {
                    method: 'GET',
                    headers: { 
                        'Authorization': `Bearer ${token}` 
                    }
                });

                const data = await response.json();

                if (response.ok) {
                    welcomeMsg.innerText = data.message;
                } else {
                    alert('Phiên đăng nhập hết hạn hoặc không có quyền!');
                    window.location.href = '/login';
                }
            } catch (err) {
                welcomeMsg.innerText = "Lỗi tải dữ liệu.";
            }
        }

        function logout() {
            localStorage.removeItem('accessToken');
            window.location.href = '/login';
        }

        fetchProfile();
    </script>
</body>
</html>