<div class="container bg-white p-4 rounded shadow" style="max-width:820px;margin-top:30px;">
  <div class="d-flex justify-content-between align-items-center">
    <h2 id="welcome-msg">Thông tin cá nhân</h2>
    <button class="btn btn-danger" id="logoutBtn">Đăng xuất</button>
  </div>
  <hr>

  <div id="profileContent">
    <p class="text-muted">Đang tải thông tin...</p>
  </div>
</div>

<script>
  async function fetchProfile() {
    const token = localStorage.getItem('accessToken');
    const welcomeMsg = document.getElementById('welcome-msg');

    const url = window.location.pathname.includes('admin')
      ? '/admin/profile/data'
      : '/user/profile/data';

    try {
      const response = await fetch(url, {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${token}`
        }
      });

      const data = await response.json();

      if (response.ok) {
        welcomeMsg.innerText = data.message;
        document.getElementById('profileContent').innerHTML = `
          <p>Email: <strong>${data.email || ''}</strong></p>
          <p>Vai trò: <strong>${data.role || ''}</strong></p>
        `;
      } else {
        alert('Phiên đăng nhập hết hạn hoặc không có quyền!');
        window.location.href = '/login';
      }
    } catch (err) {
      welcomeMsg.innerText = 'Lỗi tải dữ liệu.';
    }
  }

  function logout() {
    localStorage.removeItem('accessToken');
    window.location.href = '/login';
  }

  document.getElementById('logoutBtn').addEventListener('click', logout);
  fetchProfile();
</script>
